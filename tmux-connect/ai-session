#!/bin/bash

# ── ai-session ──────────────────────────────────────────────────────────────
# Wrapper for AI CLI tools. Launches the tool interactively, then optionally
# helps commit any changes on exit using a headless AI-generated commit message.
# Usage: ai-session <claude|codex|gemini>
# ────────────────────────────────────────────────────────────────────────────

TOOL="$1"
TOOL_BIN=""

if [ -z "$TOOL" ]; then
    echo "Usage: ai-session <claude|codex|gemini>"
    exit 1
fi

case "$TOOL" in
    claude) TOOL_BIN="claude" ;;
    codex) TOOL_BIN="codex" ;;
    gemini) TOOL_BIN="gemini" ;;
    *)
        echo "Unknown tool: $TOOL"
        exit 1
        ;;
esac

if ! command -v "$TOOL_BIN" >/dev/null 2>&1; then
    echo "$TOOL_BIN is not installed or not on PATH."
    exit 1
fi

# Pin the working directory before launching the tool so git operations
# always target the correct repo even if the tool changes the cwd.
SESSION_DIR="$(pwd)"

# ── Launch tool interactively ─────────────────────────────────────────────

case "$TOOL" in
    claude)
        claude --dangerously-skip-permissions
        ;;
    codex)
        codex --dangerously-bypass-approvals-and-sandbox
        ;;
    gemini)
        gemini --yolo
        ;;
esac
TOOL_EXIT_STATUS=$?

# ── Optional commit on exit ──────────────────────────────────────────────

# Return to the session's original directory so git targets the right repo.
cd "$SESSION_DIR"

# Respect the tool's exit status. Only offer commit assistance after a clean exit.
if [ "$TOOL_EXIT_STATUS" -ne 0 ]; then
    echo ""
    echo "  $TOOL exited with status $TOOL_EXIT_STATUS. Skipping commit prompt."
    exit "$TOOL_EXIT_STATUS"
fi

# Skip the commit prompt for scratchpad sessions: they start in the projects
# root, not inside a specific project repo. Guard with git rev-parse as well
# to catch any other non-repo directories.
if ! git rev-parse --git-dir &>/dev/null; then
    exit 0
fi

HAS_UNTRACKED=0
if [ -n "$(git ls-files --others --exclude-standard)" ]; then
    HAS_UNTRACKED=1
fi

# Only proceed if there are staged, unstaged, or untracked changes.
if git diff --quiet && git diff --cached --quiet && [ "$HAS_UNTRACKED" -eq 0 ]; then
    exit 0
fi

echo ""
echo "  Changes detected in $(basename "$(git rev-parse --show-toplevel)"):"
git status --short
echo ""
printf "  Commit changes now? (y/N): "
IFS= read -rsn1 commit_key
echo ""

if [[ "$commit_key" != "y" && "$commit_key" != "Y" ]]; then
    echo "  Leaving changes uncommitted."
    exit 0
fi

INCLUDE_UNTRACKED=0
if [ "$HAS_UNTRACKED" -eq 1 ]; then
    printf "  Include untracked files? (y/N): "
    IFS= read -rsn1 untracked_key
    echo ""
    if [[ "$untracked_key" == "y" || "$untracked_key" == "Y" ]]; then
        INCLUDE_UNTRACKED=1
    fi
fi

if [ "$INCLUDE_UNTRACKED" -eq 1 ]; then
    git add -A
else
    git add -u
fi

# Check if staging produced anything (changes might be untracked-only and skipped)
if [ -z "$(git diff --cached --name-only)" ]; then
    echo "  No staged changes to commit. Leaving working tree untouched."
    exit 0
fi

# Generate commit message via headless AI call
DIFF=$(git diff --cached)
DIFF_LINES=$(echo "$DIFF" | wc -l)
if [ "$DIFF_LINES" -gt 200 ]; then
    DIFF=$(git diff --cached --stat)
fi

case "$TOOL" in
    claude)
        MSG=$(claude -p "Write a single-line git commit message (no quotes, no prefix like 'feat:') for these changes. Output ONLY the message, nothing else: $DIFF" --dangerously-skip-permissions 2>/dev/null)
        ;;
    codex)
        MSG=$(codex exec --skip-git-repo-check --dangerously-bypass-approvals-and-sandbox "Write a single-line git commit message (no quotes, no prefix like 'feat:') for these changes. Output ONLY the message, nothing else: $DIFF" 2>/dev/null)
        ;;
    gemini)
        MSG=$(gemini -p "Write a single-line git commit message (no quotes, no prefix like 'feat:') for these changes. Output ONLY the message, nothing else: $DIFF" --yolo 2>/dev/null)
        ;;
esac

# Clean up message — remove quotes, trim whitespace
MSG=$(echo "$MSG" | sed "s/^[\"']*//;s/[\"']*$//" | xargs)

# Fallback if AI call failed or message is empty after cleanup
if [ -z "$MSG" ]; then
    MSG="wip: checkpoint from $TOOL session"
fi

printf "  Commit message [%s]: " "$MSG"
IFS= read -r custom_msg
if [ -n "$custom_msg" ]; then
    MSG=$(echo "$custom_msg" | xargs)
fi

if [ -z "$MSG" ]; then
    MSG="wip: checkpoint from $TOOL session"
fi

if git commit -m "$MSG"; then
    echo "  ✓ Committed: $MSG"
else
    echo "  ✗ Commit failed. Review the staged changes and try again."
    exit 1
fi
